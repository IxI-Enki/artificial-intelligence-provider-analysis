---
import '../styles/showcase.css';
import SearchBox from '../components/SearchBox.astro';

interface Props {
  title?: string;
  generatedAt?: string;
  staleWarning?: string | null;
}

const {
  title = 'AI Provider Landscape',
  generatedAt,
  staleWarning,
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · IxI-Enki</title>
    <meta
      name="description"
      content="Reference comparison of leading AI providers: context, API pricing, deployment type, MCP compatibility."
    />
  </head>
  <body class="neu">
    {staleWarning && (
      <div class="offline-banner" role="status">{staleWarning}</div>
    )}
    <div id="client-stale-banner" class="offline-banner client-stale-banner" role="status" hidden></div>

    <div class="bg-layer" aria-hidden="true">
      <div class="bg-parallax bg-parallax--grid"><div class="bg-grid"></div></div>
    </div>

    <header class="site">
      <div class="wrap">
        <a class="brand" href="https://ixi-enki.github.io/">IxI<span class="x">-</span>Enki</a>
        <nav class="main">
          <a href="https://ixi-enki.github.io/project-diploma-performance-analysis/">Embeddings</a>
          <a href={base} class="active">AI providers</a>
        </nav>
      </div>
    </header>

    <SearchBox />

    <main>
      <slot />
    </main>

    <footer class="site">
      <div class="wrap footer-inner">
        <div class="footer-col">
          <p class="footer-h">About</p>
          <p>Curated provider reference by Jan Ritt (IxI-Enki). Static build — no runtime API calls.</p>
        </div>
        <div class="footer-col">
          <p class="footer-h">Links</p>
          <a href="https://ixi-enki.github.io/">Portfolio</a>
          <a href="https://github.com/IxI-Enki/artificial-intelligence-provider-analysis">GitHub repo</a>
        </div>
        <div class="footer-col">
          <p class="footer-h">Freshness</p>
          {generatedAt ? (
            <p class="mono" style="font-size:.8rem">Last updated: {new Date(generatedAt).toLocaleString('en-GB', { timeZone: 'UTC' })} UTC</p>
          ) : (
            <p class="mono" style="font-size:.8rem">Build-time snapshot</p>
          )}
        </div>
      </div>
      <div class="wrap footer-base">
        <span>Jan Ritt · HTL Leonding</span>
        <span>Daily refresh 02:00 UTC</span>
      </div>
    </footer>

    <link href={base + 'pagefind/pagefind-ui.css'} rel="stylesheet" />
    <script is:inline>
      (function () {
        var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var elements = document.querySelectorAll('.reveal');
        if (!elements.length) return;
        if (reduced) {
          elements.forEach(function (el) { el.classList.add('in'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) e.target.classList.add('in');
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
        elements.forEach(function (el) { io.observe(el); });
      })();
    </script>
    <script is:inline define:vars={{ base, generatedAt }}>
      (function () {
        const REFRESH_MS = 24 * 60 * 60 * 1000;
        if (generatedAt) {
          const age = Date.now() - Date.parse(generatedAt);
          if (!Number.isNaN(age) && age > REFRESH_MS) {
            const el = document.getElementById('client-stale-banner');
            if (el) {
              const hours = Math.floor(age / 3600000);
              el.textContent =
                'Snapshot is stale on load (' + hours + 'h old). Run the deploy workflow to refresh.';
              el.hidden = false;
            }
          }
        }
        const bundle = base + 'pagefind/';
        const s = document.createElement('script');
        s.src = bundle + 'pagefind-ui.js';
        s.onload = function () {
          if (typeof PagefindUI !== 'undefined') {
            new PagefindUI({
              element: '#pagefind-search',
              bundlePath: bundle,
              showSubResults: true,
              resetStyles: false,
            });
          }
        };
        document.body.appendChild(s);
      })();
    </script>
  </body>
</html>
