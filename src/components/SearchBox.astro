---
const base = import.meta.env.BASE_URL;
---

<div class="wrap" style="margin-top:12px">
  <div id="search" class="card" style="padding:12px 16px">
    <label for="pagefind-input" class="mono" style="font-size:.75rem;display:block;margin-bottom:6px">Search models & providers</label>
    <input id="pagefind-input" type="search" placeholder="e.g. gemini, llama, embedding..." style="width:100%;padding:8px 10px;border-radius:8px;border:1px solid var(--border, #333);background:var(--surface, #111);color:inherit" />
    <div id="pagefind-results" style="margin-top:8px"></div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    if (typeof window.PagefindUI === 'undefined') return;
    // @ts-expect-error pagefind global
    new window.PagefindUI({
      element: '#pagefind-results',
      showImages: false,
      resetStyles: false,
    });
    const input = document.getElementById('pagefind-input');
    const results = document.getElementById('pagefind-results');
    if (input && results) {
      input.addEventListener('input', () => {
        const pfInput = results.querySelector('input');
        if (pfInput instanceof HTMLInputElement) {
          pfInput.value = (input as HTMLInputElement).value;
          pfInput.dispatchEvent(new Event('input', { bubbles: true }));
        }
      });
    }
  });
</script>
