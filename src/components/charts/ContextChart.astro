---
interface FieldSource {
  model_slug?: string;
}

interface Provider {
  name: string;
  context_tokens?: number | null;
  field_sources?: Record<string, FieldSource>;
}

interface Props {
  providers: Provider[];
  chartId?: string;
}

const { providers, chartId = 'context-chart' } = Astro.props;
const base = import.meta.env.BASE_URL;
const sorted = [...providers].sort(
  (a, b) => (b.context_tokens ?? 0) - (a.context_tokens ?? 0),
);

function modelSlug(p: Provider): string | undefined {
  return p.field_sources?.context_tokens?.model_slug;
}

const labels = JSON.stringify(sorted.map((p) => p.name));
const slugs = JSON.stringify(sorted.map((p) => modelSlug(p) ?? ''));
const values = JSON.stringify(sorted.map((p) => p.context_tokens ?? null));
const barCount = sorted.length;
const chartHeight = Math.max(320, barCount * 44 + 48);
---

<div class="chart-card">
  <p class="chart-subtitle">Context window via OpenRouter (log scale)</p>
  <div class="chart-wrap chart-wrap--tall" style={`height:${chartHeight}px`}>
    <canvas
      id={chartId}
      data-labels={labels}
      data-slugs={slugs}
      data-values={values}
    ></canvas>
  </div>
</div>
<script is:inline src={base + 'vendor/chart.umd.min.js'}></script>
<script define:vars={{ chartId }}>
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById(chartId);
    if (!canvas || typeof Chart === 'undefined') return;
    const labels = JSON.parse(canvas.dataset.labels || '[]');
    const slugs = JSON.parse(canvas.dataset.slugs || '[]');
    const values = JSON.parse(canvas.dataset.values || '[]');

    const fmtCtx = (v) =>
      v == null || Number.isNaN(v) ? 'n/a' : Number(v).toLocaleString('en-US');

    new Chart(canvas.getContext('2d'), {
      type: 'bar',
      data: {
        labels,
        datasets: [{ label: 'Context tokens', data: values, backgroundColor: '#6ea8fe' }],
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        layout: { padding: { right: 12 } },
        scales: {
          x: {
            type: 'logarithmic',
            title: { display: true, text: 'Tokens' },
            ticks: {
              callback: (v) => fmtCtx(v),
              maxTicksLimit: 8,
            },
          },
          y: {
            ticks: {
              autoSkip: false,
              font: { size: 12 },
            },
          },
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title: (items) => {
                const i = items[0]?.dataIndex ?? 0;
                const slug = slugs[i];
                return slug ? labels[i] + ' · ' + slug : labels[i];
              },
              label: (ctx) => 'Context: ' + fmtCtx(ctx.parsed.x) + ' tokens',
            },
          },
        },
      },
    });
  });
</script>
