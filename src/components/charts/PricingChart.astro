---
interface FieldSource {
  model_slug?: string;
}

interface Provider {
  flagship_model?: string;
  api_input_per_million?: number | null;
  api_output_per_million?: number | null;
  field_sources?: Record<string, FieldSource>;
}

interface Props {
  providers: Provider[];
  chartId?: string;
}

const { providers, chartId = 'price-chart' } = Astro.props;
const base = import.meta.env.BASE_URL;

function modelSlug(p: Provider): string | undefined {
  return (
    p.field_sources?.api_input_per_million?.model_slug ??
    p.field_sources?.context_tokens?.model_slug
  );
}

function barLabel(p: Provider): string {
  const display = p.flagship_model ?? 'n/a';
  const slug = modelSlug(p);
  return slug ? `${display}\n${slug}` : display;
}

const labels = JSON.stringify(providers.map(barLabel));
const inputData = JSON.stringify(providers.map((p) => p.api_input_per_million ?? null));
const outputData = JSON.stringify(providers.map((p) => p.api_output_per_million ?? null));
---

<div class="chart-card">
  <p class="chart-subtitle">Aggregator pricing via OpenRouter</p>
  <div class="chart-wrap">
    <canvas
      id={chartId}
      data-labels={labels}
      data-input={inputData}
      data-output={outputData}
    ></canvas>
  </div>
</div>
<script is:inline src={base + 'vendor/chart.umd.min.js'}></script>
<script define:vars={{ chartId }}>
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById(chartId);
    if (!canvas || typeof Chart === 'undefined') return;
    const labels = JSON.parse(canvas.dataset.labels || '[]');
    const inputData = JSON.parse(canvas.dataset.input || '[]');
    const outputData = JSON.parse(canvas.dataset.output || '[]');
    new Chart(canvas.getContext('2d'), {
      type: 'bar',
      data: {
        labels,
        datasets: [
          { label: 'Input / 1M USD', data: inputData, backgroundColor: '#6ea8fe' },
          { label: 'Output / 1M USD', data: outputData, backgroundColor: '#a78bfa' },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            ticks: {
              font: (ctx) => {
                const label = labels[ctx.index] ?? '';
                return { size: String(label).includes('\n') ? 10 : 11 };
              },
              maxRotation: 0,
              autoSkip: false,
            },
          },
          y: { beginAtZero: true },
        },
      },
    });
  });
</script>
