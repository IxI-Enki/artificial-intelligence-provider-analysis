{
  "name": "artificial-intelligence-provider-analysis",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/sync-data.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "test:unit": "vitest run",
    "verify:static": "node scripts/verify-static.mjs",
    "pagefind:index": "pagefind --site dist --output-path dist/pagefind && node scripts/copy_pagefind.mjs",
    "postbuild": "npm run pagefind:index && npm run verify:static"
  },
  "dependencies": {
    "@astrojs/svelte": "^7.0.0",
    "astro": "^5.0.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "pagefind": "^1.3.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
